# Auth (required for login + middleware)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1h
# Set false when running production build over plain HTTP (no TLS)
SESSION_COOKIE_SECURE=false

# External MySQL (central app) settings
DB_HOST=your.mysql.host
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=host2host

# External Sage MSSQL settings
SAGE_DB_HOST=your.sage.db.host
SAGE_DB_PORT=1433
SAGE_DB_USER=sa
SAGE_DB_PASSWORD=your_sapassword
SAGE_DB_NAME=INDCOM

# Redis (used by agents). If you have an external redis set host/port here.
REDIS_HOST=redis
REDIS_PORT=6379

# ZICB agent settings (optional)
ZICB_PORT=4001
